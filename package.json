{
  "name": "airplane-banner",
  "version": "0.1.0",
  "description": "An airplane flies a banner across your screen before Google Calendar meetings.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "license": "MIT",
  "build": {
    "appId": "com.adelina.airplanebanner",
    "productName": "Airplane Banner",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": 1
      }
    },
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AdelinaLipsa",
        "repo": "airplane-banner"
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.0"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "google-auth-library": "^9.0.0",
    "googleapis": "^140.0.0"
  }
}
